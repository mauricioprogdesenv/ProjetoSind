object frmImportacao: TfrmImportacao
  Caption = 'Importacao de Funcionarios CSV'
  ClientHeight = 240
  ClientWidth = 640
  Position = poScreenCenter
  OnCreate = FormCreate
  object LabelMes: TLabel
    Left = 16
    Top = 16
    Caption = 'Mes'
  end
  object edtMes: TEdit
    Left = 16
    Top = 32
    Width = 64
    Anchors = [akLeft, akTop]
    TabOrder = 0
  end
  object LabelAno: TLabel
    Left = 96
    Top = 16
    Caption = 'Ano'
  end
  object edtAno: TEdit
    Left = 96
    Top = 32
    Width = 80
    TabOrder = 1
  end
  object LabelIdAssoc: TLabel
    Left = 192
    Top = 16
    Caption = 'ID Associado'
  end
  object edtIdAssociado: TEdit
    Left = 192
    Top = 32
    Width = 96
    TabOrder = 2
  end
  object btn_Consultar: TButton
    Left = 296
    Top = 30
    Width = 96
    Height = 24
    Caption = 'Consultar...'
    TabOrder = 3
    OnClick = btn_ConsultarClick
  end
  object LabelArq: TLabel
    Left = 16
    Top = 72
    Caption = 'Arquivo CSV'
  end
  object edtArquivo: TFileNameEdit
    Left = 16
    Top = 88
    Width = 584
    Height = 24
    Filter = 'Arquivos CSV|*.csv'
    NumGlyphs = 1
    TabOrder = 4
  end
  object btnExecutar: TButton
    Left = 424
    Top = 184
    Width = 88
    Height = 28
    Caption = 'Executar'
    Anchors = [akRight, akBottom]
    TabOrder = 5
    OnClick = btnExecutarClick
  end
  object btnCancelar: TButton
    Left = 520
    Top = 184
    Width = 88
    Height = 28
    Caption = 'Cancelar'
    Anchors = [akRight, akBottom]
    TabOrder = 6
    OnClick = btnCancelarClick
  end
  object OpenDialog1: TOpenDialog
    InitialDir = 'D:\SISTEMA\WSIND\CSV'
    Filter = 'Arquivos CSV|*.csv'
    Options = [ofFileMustExist, ofEnableSizing]
    Left = 560
    Top = 16
  end
end
